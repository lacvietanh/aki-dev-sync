{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aki Dev Sync",
  "version": "../package.json",
  "identifier": "aki.devsync",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aki Dev Sync",
        "width": 875,
        "height": 768,
        "minWidth": 600,
        "minHeight": 500,
        "transparent": true,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "rsync-based remote deploy workflow manager",
    "longDescription": "Aki Dev Sync is a dark-mode desktop tool for managing rsync-based deployment workflows between local and remote machines via SSH.",
    "copyright": "© 2026 Aki",
    "publisher": "Aki",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "background": "../dev/app-dmg-bg.png",
        "windowSize": {
          "width": 540,
          "height": 420
        },
        "appPosition": {
          "x": 127,
          "y": 210
        },
        "applicationFolderPosition": {
          "x": 414,
          "y": 210
        },
        "windowPosition": {
          "x": 500,
          "y": 100
        }
      }
    }
  }
}